# ── Base de datos PostgreSQL ──────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=escuela_dominical
PGUSER=postgres
PGPASSWORD=tu_password_aqui

# ── Seguridad ────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_min_32_chars
JWT_EXPIRA_EN=8h
BCRYPT_SALT_ROUNDS=12

# ── Rate Limiting ────────────────────────────────────────────────
# Minutos de bloqueo tras 3 intentos fallidos de login
MINUTOS_BLOQUEO_LOGIN=15

# ── Servidor ─────────────────────────────────────────────────────
PUERTO=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGEN=http://localhost:5175
